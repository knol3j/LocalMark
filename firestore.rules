rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidCampaign(data) {
      return data.keys().hasAll(['activePrompt', 'activeTab', 'updatedAt']) &&
             data.activePrompt is string && data.activePrompt.size() <= 5000 &&
             data.activeTab is string && data.activeTab.size() <= 50 &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt', 'authorId']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.createdAt == request.time &&
             data.authorId == request.auth.uid &&
             (!('image' in data) || (data.image == null || (data.image is string && data.image.size() <= 1000000)));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'lastSeen']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             data.lastSeen == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
    }

    match /campaigns/{campaignId} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(campaignId) && isValidCampaign(incoming());

      match /messages/{messageId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && 
                        isValidId(messageId) && 
                        isValidMessage(incoming()) && 
                        exists(/databases/$(database)/documents/campaigns/$(campaignId));
        allow update, delete: if false;
      }
    }
  }
}
