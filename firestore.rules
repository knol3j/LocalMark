rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidCampaign(data) {
      return data.keys().hasAll(['activePrompt', 'activeTab', 'updatedAt']) &&
             data.activePrompt is string && data.activePrompt.size() <= 5000 &&
             data.activeTab is string && data.activeTab.size() <= 50 &&
             (!('enabledModules' in data) || (data.enabledModules is list && data.enabledModules.size() <= 20)) &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt', 'authorId']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.createdAt == request.time &&
             data.authorId == request.auth.uid &&
             (!('image' in data) || (data.image == null || (data.image is string && data.image.size() <= 1000000)));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'lastSeen']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             data.lastSeen == request.time;
    }

    function isValidVariation(data) {
      return data.keys().hasAll(['label', 'copy', 'ctr', 'conv', 'platform', 'audience', 'trend']) &&
             data.label is string && data.label.size() <= 200 &&
             data.copy is string && data.copy.size() <= 2000 &&
             data.ctr is number && data.conv is number &&
             data.platform is string && data.audience is string &&
             data.trend in ['up', 'down', 'stable'];
    }

    function isValidPersona(data) {
      return data.keys().hasAll(['name', 'demographics', 'pains', 'gains', 'engagementScore']) &&
             data.name is string && data.name.size() <= 100 &&
             data.demographics is string &&
             data.pains is list && data.gains is list &&
             data.engagementScore is number;
    }

    function isValidMetric(data) {
      return data.keys().hasAll(['timestamp', 'ctr', 'conv', 'spend']) &&
             data.timestamp is string &&
             data.ctr is number && data.conv is number && data.spend is number;
    }

    function isValidKeyword(data) {
      return data.keys().hasAll(['term', 'volume', 'difficulty', 'intent']) &&
             data.term is string && data.term.size() <= 200 &&
             data.volume is string && data.difficulty is string &&
             data.intent is string;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
    }

    match /campaigns/{campaignId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(campaignId) && isValidCampaign(incoming());

      match /messages/{messageId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && 
                        isValidId(messageId) && 
                        isValidMessage(incoming()) && 
                        exists(/databases/$(database)/documents/campaigns/$(campaignId));
        allow update, delete: if false;
      }

      match /variations/{variationId} {
        allow list, get: if isSignedIn();
        allow create, update: if isSignedIn() && 
                               isValidId(variationId) && 
                               isValidVariation(incoming());
        allow delete: if isSignedIn();
      }

      match /personas/{personaId} {
        allow list, get: if isSignedIn();
        allow create, update: if isSignedIn() && 
                               isValidId(personaId) && 
                               isValidPersona(incoming());
        allow delete: if isSignedIn();
      }

      match /keywords/{keywordId} {
        allow list, get: if isSignedIn();
        allow create, update: if isSignedIn() && 
                               isValidId(keywordId) && 
                               isValidKeyword(incoming());
        allow delete: if isSignedIn();
      }

      match /metrics/{metricId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && isValidMetric(incoming());
      }
    }
  }
}
